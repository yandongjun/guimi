page {
  min-height: 100%;
  background: #f7f1ec;
  color: #2f2925;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.section {
  margin-top: 28rpx;
}

.card {
  border-radius: 16rpx;
  background: #fffaf6;
  border: 1rpx solid rgba(66, 52, 45, 0.08);
  box-shadow: 0 10rpx 30rpx rgba(63, 49, 42, 0.06);
  padding: 28rpx;
}

.title {
  font-size: 44rpx;
  line-height: 1.15;
  font-weight: 700;
  letter-spacing: 0;
}

.subtitle {
  margin-top: 12rpx;
  color: #756962;
  font-size: 26rpx;
  line-height: 1.55;
}

.eyebrow {
  color: #9a493f;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.row {
  display: flex;
  align-items: center;
}

.space-between {
  justify-content: space-between;
}

.primary-button,
.ghost-button,
.tiny-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  border-radius: 999rpx;
  font-weight: 700;
  line-height: 1;
}

.primary-button {
  min-height: 88rpx;
  padding: 0 34rpx;
  color: #fffaf6;
  background: #2f2925;
}

.ghost-button {
  min-height: 72rpx;
  padding: 0 28rpx;
  color: #2f2925;
  background: #efe4dd;
}

.tiny-button {
  min-height: 58rpx;
  padding: 0 22rpx;
  font-size: 22rpx;
  color: #9a493f;
  background: #f4ddd5;
}

.primary-button::after,
.ghost-button::after,
.tiny-button::after {
  border: none;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #efe4dd;
  color: #6c5f58;
  font-size: 22rpx;
}

.muted {
  color: #7b6f68;
}

.divider {
  height: 1rpx;
  background: rgba(66, 52, 45, 0.08);
  margin: 24rpx 0;
}

.swatch {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 3rpx solid #fffaf6;
  box-shadow: 0 0 0 1rpx rgba(66, 52, 45, 0.12);
}

.empty {
  padding: 44rpx 24rpx;
  text-align: center;
  color: #7b6f68;
  font-size: 26rpx;
}
