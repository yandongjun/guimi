<view class="mili-chat">
  <view wx:if="{{open}}" class="chat-mask" catchtap="closeChat"></view>

  <view wx:if="{{open}}" class="chat-panel">
    <view class="chat-head">
      <view class="mili-avatar small">
        <view class="hair"></view>
        <view class="face">
          <view class="eye left"></view>
          <view class="eye right"></view>
          <view class="mouth"></view>
        </view>
      </view>
      <view class="chat-title">
        <text>米粒</text>
        <view>我会慢慢记住你的偏好</view>
      </view>
      <view class="close" catchtap="closeChat">×</view>
    </view>

    <scroll-view scroll-y class="message-list">
      <view wx:for="{{messages}}" wx:key="id" class="message {{item.from}}">
        <text>{{item.text}}</text>
      </view>
    </scroll-view>

    <view class="quick-row">
      <text
        wx:for="{{quickActions}}"
        wx:key="text"
        data-text="{{item.text}}"
        catchtap="sendQuick"
        class="quick"
      >{{item.label}}</text>
    </view>

    <view class="input-row">
      <input
        value="{{draft}}"
        bindinput="onInput"
        confirm-type="send"
        bindconfirm="sendMessage"
        placeholder="告诉米粒：年龄、星座、今天去哪、想显瘦还是有气质"
      />
      <button catchtap="sendMessage">发送</button>
    </view>
  </view>

  <view class="chat-fab" catchtap="openChat">
    <view class="mili-avatar">
      <view class="hair"></view>
      <view class="face">
        <view class="eye left"></view>
        <view class="eye right"></view>
        <view class="mouth"></view>
      </view>
    </view>
    <text>米粒</text>
  </view>
</view>
