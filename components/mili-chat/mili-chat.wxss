.chat-fab {
  position: fixed;
  right: 24rpx;
  bottom: calc(148rpx + env(safe-area-inset-bottom));
  z-index: 60;
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 70rpx;
  padding: 8rpx 16rpx 8rpx 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 246, 0.92);
  border: 1rpx solid rgba(66, 52, 45, 0.12);
  box-shadow: 0 12rpx 32rpx rgba(47, 41, 37, 0.16);
  color: #7f1019;
  font-size: 22rpx;
  font-weight: 900;
}

.mili-avatar {
  position: relative;
  flex: 0 0 54rpx;
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  background: #f3e6d8;
  overflow: hidden;
  border: 1rpx solid rgba(66, 52, 45, 0.1);
}

.mili-avatar.small {
  flex-basis: 68rpx;
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
}

.hair {
  position: absolute;
  left: 9rpx;
  right: 9rpx;
  top: 8rpx;
  height: 22rpx;
  border-radius: 18rpx 18rpx 8rpx 8rpx;
  background: #3a302b;
  z-index: 2;
}

.small .hair {
  left: 12rpx;
  right: 12rpx;
  top: 10rpx;
  height: 28rpx;
}

.face {
  position: absolute;
  left: 9rpx;
  right: 9rpx;
  bottom: 7rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #d8a58c;
}

.small .face {
  left: 11rpx;
  right: 11rpx;
  bottom: 8rpx;
  height: 48rpx;
}

.eye {
  position: absolute;
  top: 18rpx;
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: #322924;
}

.eye.left {
  left: 11rpx;
}

.eye.right {
  right: 11rpx;
}

.mouth {
  position: absolute;
  left: 50%;
  bottom: 9rpx;
  width: 18rpx;
  height: 3rpx;
  border-radius: 999rpx;
  transform: translateX(-50%);
  background: #513c35;
}

.chat-mask {
  position: fixed;
  inset: 0;
  z-index: 70;
  background: rgba(47, 41, 37, 0.16);
}

.chat-panel {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  z-index: 80;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #fffaf6;
  border: 1rpx solid rgba(66, 52, 45, 0.1);
  box-shadow: 0 18rpx 48rpx rgba(47, 41, 37, 0.18);
}

.chat-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.chat-title {
  flex: 1;
  min-width: 0;
}

.chat-name {
  color: #2f2925;
  font-size: 30rpx;
  font-weight: 900;
}

.chat-desc {
  margin-top: 4rpx;
  color: #7b6f68;
  font-size: 22rpx;
}

.close {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #efe4dd;
  color: #6c5f58;
  font-size: 34rpx;
}

.message-list {
  height: 330rpx;
  margin-top: 22rpx;
}

.message {
  max-width: 84%;
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  font-size: 25rpx;
  line-height: 1.45;
}

.message.mili {
  margin-right: auto;
  background: #f3ebe4;
  color: #4d423c;
}

.message.user {
  margin-left: auto;
  background: #9a1621;
  color: #fffaf6;
}

.quick-row {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  padding-top: 14rpx;
}

.quick {
  flex: 0 0 auto;
  min-height: 52rpx;
  display: inline-flex;
  align-items: center;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #edf3ed;
  color: #4b6552;
  font-size: 22rpx;
  font-weight: 800;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.chat-input {
  flex: 1;
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #f7f1ec;
  color: #2f2925;
  font-size: 24rpx;
}

.send-btn {
  flex: 0 0 112rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  border-radius: 999rpx;
  background: #2f2925;
  color: #fffaf6;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.send-btn::after {
  border: none;
}
