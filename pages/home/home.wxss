    linear-gradient(90deg, rgba(251, 246, 238, 0.78) 0%, rgba(251, 246, 238, 0.22) 33%, rgba(251, 246, 238, 0) 58%);
  pointer-events: none;
}

.editorial-title {
  top: 332rpx;
  left: 76rpx;
  width: 220rpx;
  max-width: 220rpx;
  font-size: 38rpx;
