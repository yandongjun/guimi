  letter-spacing: 0;
}

.editorial-title text {
  display: block;
}

.mood {
  top: 530rpx;
  left: 78rpx;
  right: 404rpx;
  font-size: 22rpx;
  line-height: 1.35;
}

.look-code {
  bottom: 318rpx;
  left: 76rpx;
}

.editorial-card {
  position: absolute;
  left: 64rpx;
  right: 42rpx;
  bottom: 76rpx;
  z-index: 9;
  padding: 14rpx 20rpx 12rpx;
  border-radius: 24rpx;
  background: rgba(255, 250, 246, 0.48);
  border: 1rpx solid rgba(127, 16, 25, 0.06);
  box-shadow: 0 -8rpx 24rpx rgba(83, 61, 45, 0.04);
  backdrop-filter: blur(6rpx);
}

.editorial-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.editorial-card-title {
  color: rgba(23, 18, 16, 0.82);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  font-size: 21rpx;
  line-height: 1.25;
  font-weight: 900;
}

.editorial-card-action {
  min-height: 38rpx;
  padding: 0 16rpx;
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  background: rgba(127, 16, 25, 0.82);
  color: #fffaf2;
  font-size: 19rpx;
  font-weight: 900;
}

.editorial-closet {
  margin-top: 8rpx;
  color: rgba(74, 49, 42, 0.76);
  font-size: 18rpx;
  line-height: 1.3;
  font-weight: 800;
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  min-width: 0;
}

.editorial-closet-label,
.editorial-closet-copy {
  display: inline;
}

.editorial-closet-label {
  color: rgba(127, 16, 25, 0.72);
  font-size: 17rpx;
  letter-spacing: 1rpx;
}

.editorial-closet-copy {
  margin-top: 4rpx;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.editorial-reasons {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.editorial-reason {
  min-width: 0;
}

.editorial-index {
  display: block;
  color: rgba(127, 16, 25, 0.7);
  font-size: 17rpx;
  font-weight: 900;
}

.editorial-copy {
  display: block;
  margin-top: 4rpx;
  color: rgba(23, 18, 16, 0.74);
  font-size: 17rpx;
  line-height: 1.25;
  font-weight: 800;
}

.editorial-palette {
  position: static;
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
}

.brand-mark {
  bottom: 28rpx;
  opacity: 0.42;
}

.theme-pink .editorial-card {
  background: rgba(255, 248, 248, 0.54);
}

.theme-pink .editorial-card-title,
.theme-pink .editorial-index,
.theme-pink .editorial-closet-label {
  color: rgba(167, 51, 88, 0.76);
}

.theme-pink .editorial-card-action {
  background: rgba(167, 51, 88, 0.9);
}

.theme-cool .editorial-card {
  background: rgba(18, 47, 66, 0.82);
  border-color: rgba(200, 240, 255, 0.16);
}

.theme-cool .editorial-card-title,
.theme-cool .editorial-index,
.theme-cool .editorial-closet-label {
  color: rgba(122, 215, 255, 0.82);
}

.theme-cool .editorial-copy,
.theme-cool .editorial-closet {
  color: rgba(237, 247, 251, 0.76);
}

.feedback-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.feedback-button {
  min-width: 48rpx;
  height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(127, 16, 25, 0.1);
  color: rgba(127, 16, 25, 0.86);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 19rpx;
  font-weight: 900;
}

.feedback-button.active {
  color: #fffaf2;
  background: rgba(127, 16, 25, 0.88);
}

.left-info-stack {
  position: absolute;
  left: 78rpx;
  top: 575rpx;
  z-index: 8;
  width: 255rpx;
}

.left-info-item {
  padding: 15rpx 0 16rpx;
  border-bottom: 1rpx solid rgba(23, 18, 16, 0.14);
}

.left-info-label {
  display: block;
  color: rgba(23, 18, 16, 0.9);
  font-size: 21rpx;
  line-height: 1.2;
  font-weight: 900;
}

.left-info-copy {
  display: block;
  margin-top: 8rpx;
  color: rgba(23, 18, 16, 0.58);
  font-size: 18rpx;
  line-height: 1.38;
  font-weight: 760;
  white-space: normal;
  word-break: break-all;
}

.editorial-card {
  left: 92rpx;
  right: 56rpx;
  bottom: 78rpx;
  padding: 10rpx 16rpx 8rpx;
  background: rgba(255, 250, 246, 0.26);
  border-color: rgba(127, 16, 25, 0.04);
  box-shadow: 0 -6rpx 18rpx rgba(83, 61, 45, 0.03);
  backdrop-filter: blur(4rpx);
}

.editorial-card-head {
  min-height: 38rpx;
}

.editorial-card-title {
  max-width: 360rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.editorial-palette {
  margin-top: 8rpx;
  width: 360rpx;
}

.theme-pink .editorial-card {
  background: rgba(255, 248, 248, 0.38);
}

.theme-pink .left-info-label {
  color: rgba(128, 24, 52, 0.9);
}

.theme-cool .left-info-label {
  color: rgba(237, 247, 251, 0.9);
}

.theme-cool .left-info-copy {
  color: rgba(237, 247, 251, 0.68);
}

/* Compact right-side feedback rail */
.editorial-card {
  left: auto;
  right: 48rpx;
  bottom: 88rpx;
  width: 118rpx;
  min-height: 166rpx;
  padding: 14rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  gap: 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 250, 246, 0.2);
  border-color: rgba(127, 16, 25, 0.035);
  box-shadow: none;
  backdrop-filter: blur(3rpx);
}

.editorial-card-head,
.editorial-card-title {
  display: none;
}

.editorial-palette {
  width: 100%;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.editorial-palette .swatch {
  width: 100%;
  height: 12rpx;
}

.feedback-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 10rpx;
}

.feedback-button {
  min-width: 0;
  width: 100%;
  height: 40rpx;
  padding: 0;
  border-radius: 999rpx;
  background: rgba(127, 16, 25, 0.08);
  color: rgba(127, 16, 25, 0.76);
  font-size: 18rpx;
}

.feedback-button.active {
  background: rgba(127, 16, 25, 0.88);
  color: #fffaf2;
}

.theme-pink .editorial-card {
  background: rgba(255, 248, 248, 0.22);
}

.theme-cool .editorial-card {
  background: rgba(18, 47, 66, 0.34);
  border-color: rgba(200, 240, 255, 0.08);
}
