.readiness {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #edf3ed;
  color: #4b6552;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.color-row,
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.category-row {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.category {
  flex: 0 0 auto;
  height: 64rpx;
  min-height: 64rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #efe4dd;
  color: #6c5f58;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 800;
}

.category.active {
  color: #fffaf6;
  background: #2f2925;
}

.category::after {
  border: none;
}

.closet-list {
  display: grid;
  gap: 16rpx;
}

.item-card {
  display: grid;
  grid-template-columns: 112rpx 1fr;
  gap: 20rpx;
  align-items: center;
}

.item-visual {
  width: 116rpx;
  height: 116rpx;
  border-radius: 16rpx;
  background: #efe4dd;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-image {
  width: 100%;
  height: 100%;
  display: block;
}

.item-fallback {
  color: rgba(47, 41, 37, 0.46);
  font-size: 22rpx;
  font-weight: 800;
}

.color-0 {
  background: #f3eadb;
}

.color-1 {
  background: #a7bba5;
}

.color-2 {
  background: #233c5d;
}

.color-3 {
  background: #171514;
}

.item-name {
  font-size: 29rpx;
  font-weight: 900;
}

.item-meta-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.item-meta-part {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(239, 228, 221, 0.72);
}

.item-meta-label {
  color: rgba(95, 84, 78, 0.58);
  font-size: 18rpx;
  font-weight: 800;
}

.item-meta-value {
  color: #4b3d36;
  font-size: 20rpx;
  font-weight: 900;
}

.item-path {
  display: inline-flex;
  margin-top: 9rpx;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  background: #fff0e6;
  color: #a36359;
  font-size: 19rpx;
  font-weight: 850;
}

.item-path.success {
  background: #edf3ed;
  color: #4b6552;
}

.analysis-status {
  display: inline-flex;
  max-width: 100%;
  margin-top: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.35;
  font-weight: 800;
}

.analysis-status.success {
  background: #edf3ed;
  color: #4b6552;
}

.analysis-status.warning {
  background: #fff0e6;
  color: #a36331;
}

.mini-tag {
  display: inline-flex;
  min-height: 40rpx;
  align-items: center;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(244, 221, 213, 0.72);
  color: #9a493f;
  font-size: 20rpx;
}

.upload-error {
  border: 1rpx solid rgba(154, 22, 33, 0.18);
  background: rgba(255, 246, 244, 0.96);
}

.upload-error-copy {
  margin-top: 10rpx;
  color: #9a1621;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 800;
  word-break: break-all;
}

.upload-error-hint {
  margin-top: 8rpx;
  color: rgba(95, 84, 78, 0.72);
  font-size: 21rpx;
  line-height: 1.45;
}

.gap-item {
  padding: 18rpx 0;
  color: #5f544e;
  font-size: 26rpx;
  line-height: 1.5;
  border-bottom: 1rpx solid rgba(66, 52, 45, 0.08);
}

.gap-item:last-child {
  border-bottom: 0;
}
