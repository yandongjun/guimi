.record-page {
  padding-bottom: 44rpx;
}

.record-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin: 10rpx 0 24rpx;
}

.record-quota {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(134, 107, 82, 0.18);
  background: rgba(255, 250, 244, 0.8);
  color: #8f1d2b;
  font-size: 22rpx;
  font-weight: 800;
}

.record-header-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.sync-button {
  margin: 0;
  padding: 0 18rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  background: #8f1d2b;
  color: #fffaf4;
  font-size: 22rpx;
  font-weight: 800;
}

.sync-button[disabled] {
  color: rgba(255, 250, 244, 0.72);
  background: rgba(143, 29, 43, 0.56);
}

.record-card {
  display: flex;
  gap: 22rpx;
  padding: 20rpx;
  margin-bottom: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 250, 244, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(70, 44, 24, 0.08);
}

.record-cover {
  position: relative;
  width: 172rpx;
  height: 228rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fbf6ef 0%, #eadfd2 100%);
}

.record-image {
  width: 100%;
  height: 100%;
}

.record-preview-mask {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  min-height: 38rpx;
  border-radius: 999rpx;
  background: rgba(47, 41, 37, 0.58);
  color: #fffaf4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 19rpx;
  font-weight: 900;
  backdrop-filter: blur(4rpx);
}

.empty-cover {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed rgba(142, 31, 43, 0.22);
}

.record-empty-text {
  color: #9a1621;
  font-size: 22rpx;
  font-weight: 800;
}

.record-body {
  min-width: 0;
  flex: 1;
}

.record-line {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.record-title {
  color: #381e1c;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.record-status {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.status-ready {
  color: #1e5a45;
  background: rgba(142, 177, 159, 0.22);
}

.status-failed {
  color: #9a1621;
  background: rgba(154, 22, 33, 0.1);
}

.status-working {
  color: #805d28;
  background: rgba(205, 170, 92, 0.18);
}

.status-muted {
  color: #6b625a;
  background: rgba(70, 44, 24, 0.08);
}

.record-subtitle,
.record-closet,
.record-error {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.5;
}

.record-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.record-chip {
  display: inline-flex;
  min-height: 34rpx;
  align-items: center;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(239, 228, 221, 0.86);
  color: #6f574c;
  font-size: 19rpx;
  font-weight: 850;
}

.record-chip.warning {
  background: rgba(255, 240, 230, 0.92);
  color: #a36331;
}

.record-subtitle {
  color: #7b6a5c;
}

.record-closet {
  color: #8f1d2b;
}

.record-error {
  color: #9a1621;
}

.record-action {
  width: 100%;
  margin-top: 18rpx;
}
