.upload-panel {
  min-height: 620rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #2f2925 0%, #6f6f62 50%, #d8c7b7 100%);
  color: #fffaf6;
}

.upload-panel image {
  width: 100%;
  height: 620rpx;
}

.upload-placeholder {
  min-height: 620rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 36rpx;
}

.upload-placeholder .subtitle,
.upload-placeholder .eyebrow {
  color: rgba(255, 250, 246, 0.76);
}

.score-title {
  margin-top: 10rpx;
  color: #2f2925;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.big-score {
  flex: 0 0 92rpx;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #2f2925;
  color: #fffaf6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 900;
}

.evidence {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(66, 52, 45, 0.08);
}

.evidence:last-child {
  border-bottom: 0;
}

.evidence-title {
  font-size: 30rpx;
  font-weight: 800;
}

.evidence-score {
  color: #9a493f;
  font-weight: 900;
}

.evidence-detail {
  margin-top: 12rpx;
  color: #756962;
  font-size: 25rpx;
  line-height: 1.55;
}

.action-item {
  padding: 18rpx 0;
  color: #5f544e;
  font-size: 27rpx;
  border-bottom: 1rpx solid rgba(66, 52, 45, 0.08);
}

.action-item:last-child {
  border-bottom: 0;
}
